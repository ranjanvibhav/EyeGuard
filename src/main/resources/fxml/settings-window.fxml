<?xml version="1.0" encoding="UTF-8"?>

<?import com.eyeguard.util.ToggleSwitch?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.eyeguard.view.SettingsWindowController"
            stylesheets="@../css/settings-window.css"
            styleClass="settings-container">

    <top>
        <HBox styleClass="settings-header" alignment="CENTER_LEFT" spacing="12">
            <padding>
                <Insets top="24" right="32" bottom="24" left="32"/>
            </padding>
            <Label text="Settings" styleClass="settings-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="closeButton" text="✕" onAction="#handleClose" styleClass="btn-flat"/>
        </HBox>
    </top>

    <center>
        <TabPane fx:id="settingsTabPane" styleClass="settings-tab-pane" tabClosingPolicy="UNAVAILABLE">
            <tabs>
                <!-- TAB 1: Timer Settings -->
                <Tab text="Timer">
                    <content>
                        <VBox spacing="24" styleClass="tab-content-container">
                            <padding>
                                <Insets top="32" right="32" bottom="32" left="32"/>
                            </padding>

                            <!-- Reminder Interval -->
                            <VBox spacing="8">
                                <Label text="Reminder Interval" styleClass="section-heading"/>
                                <Label text="How often to remind you to take a break" styleClass="section-description"/>
                                <HBox spacing="12" alignment="CENTER_LEFT">
                                    <Slider fx:id="reminderIntervalSlider" min="5" max="60" value="20"
                                            majorTickUnit="5" showTickLabels="true" showTickMarks="true" HBox.hgrow="ALWAYS"/>
                                    <Label fx:id="reminderIntervalLabel" text="20 min" styleClass="slider-value-label"/>
                                </HBox>
                            </VBox>

                            <Separator styleClass="settings-divider"/>

                            <!-- Break Duration -->
                            <VBox spacing="8">
                                <Label text="Break Duration" styleClass="section-heading"/>
                                <Label text="How long each eye break lasts" styleClass="section-description"/>
                                <HBox spacing="12" alignment="CENTER_LEFT">
                                    <Slider fx:id="breakDurationSlider" min="10" max="60" value="20"
                                            majorTickUnit="10" showTickLabels="true" showTickMarks="true" HBox.hgrow="ALWAYS"/>
                                    <Label fx:id="breakDurationLabel" text="20 sec" styleClass="slider-value-label"/>
                                </HBox>
                            </VBox>

                            <Separator styleClass="settings-divider"/>

                            <!-- Snooze Duration -->
                            <VBox spacing="8">
                                <Label text="Default Snooze Duration" styleClass="section-heading"/>
                                <Label text="How long to snooze when you postpone a break" styleClass="section-description"/>
                                <ChoiceBox fx:id="snoozeDurationChoice" maxWidth="Infinity"/>
                            </VBox>
                        </VBox>
                    </content>
                </Tab>

                <!-- TAB 2: Schedule Settings -->
                <Tab text="Schedule">
                    <content>
                        <VBox spacing="24" styleClass="tab-content-container">
                            <padding>
                                <Insets top="32" right="32" bottom="32" left="32"/>
                            </padding>

                            <!-- Working Hours Toggle -->
                            <HBox alignment="CENTER_LEFT" spacing="16">
                                <VBox spacing="4" HBox.hgrow="ALWAYS">
                                    <Label text="Working Hours" styleClass="section-heading"/>
                                    <Label text="Only remind during these hours" styleClass="section-description"/>
                                </VBox>
                                <ToggleSwitch fx:id="workingHoursToggle"/>
                            </HBox>

                            <!-- Working Hours Time Range -->
                            <HBox fx:id="timeRangeContainer" spacing="16" alignment="CENTER_LEFT">
                                <VBox spacing="4">
                                    <Label text="From" styleClass="section-description"/>
                                    <ChoiceBox fx:id="workStartChoice"/>
                                </VBox>
                                <Label text="to" styleClass="range-to-label"/>
                                <VBox spacing="4">
                                    <Label text="To" styleClass="section-description"/>
                                    <ChoiceBox fx:id="workEndChoice"/>
                                </VBox>
                            </HBox>

                            <Separator styleClass="settings-divider"/>

                            <!-- Weekend Toggle -->
                            <HBox alignment="CENTER_LEFT" spacing="16">
                                <VBox spacing="4" HBox.hgrow="ALWAYS">
                                    <Label text="Remind on Weekends" styleClass="section-heading"/>
                                    <Label text="Receive reminders on Saturday and Sunday" styleClass="section-description"/>
                                </VBox>
                                <ToggleSwitch fx:id="weekendToggle"/>
                            </HBox>
                        </VBox>
                    </content>
                </Tab>

                <!-- TAB 3: Behaviour Settings -->
                <Tab text="Behaviour">
                    <content>
                        <VBox spacing="24" styleClass="tab-content-container">
                            <padding>
                                <Insets top="32" right="32" bottom="32" left="32"/>
                            </padding>

                            <!-- Fullscreen Pause -->
                            <HBox alignment="CENTER_LEFT" spacing="16">
                                <VBox spacing="4" HBox.hgrow="ALWAYS">
                                    <Label text="Pause During Fullscreen" styleClass="section-heading"/>
                                    <Label text="Auto-pause during presentations and calls" styleClass="section-description"/>
                                </VBox>
                                <ToggleSwitch fx:id="fullscreenPauseToggle"/>
                            </HBox>

                            <Separator styleClass="settings-divider"/>

                            <!-- Idle Detection -->
                            <HBox alignment="CENTER_LEFT" spacing="16">
                                <VBox spacing="4" HBox.hgrow="ALWAYS">
                                    <Label text="Pause When Idle" styleClass="section-heading"/>
                                    <Label text="Pause timer if no activity is detected" styleClass="section-description"/>
                                </VBox>
                                <ToggleSwitch fx:id="idleDetectionToggle"/>
                            </HBox>

                            <Separator styleClass="settings-divider"/>

                            <!-- Sound Alerts -->
                            <HBox alignment="CENTER_LEFT" spacing="16">
                                <VBox spacing="4" HBox.hgrow="ALWAYS">
                                    <Label text="Sound Alerts" styleClass="section-heading"/>
                                    <Label text="Play a chime before the overlay appears" styleClass="section-description"/>
                                </VBox>
                                <ToggleSwitch fx:id="soundAlertToggle"/>
                            </HBox>

                            <Separator styleClass="settings-divider"/>

                            <!-- Launch at Startup -->
                            <HBox alignment="CENTER_LEFT" spacing="16">
                                <VBox spacing="4" HBox.hgrow="ALWAYS">
                                    <Label text="Launch at Startup" styleClass="section-heading"/>
                                    <Label text="Start EyeGuard automatically on login" styleClass="section-description"/>
                                </VBox>
                                <ToggleSwitch fx:id="startupToggle"/>
                            </HBox>
                        </VBox>
                    </content>
                </Tab>
            </tabs>
        </TabPane>
    </center>

    <bottom>
        <HBox spacing="12" alignment="CENTER_RIGHT" styleClass="settings-footer">
            <padding>
                <Insets top="20" right="32" bottom="32" left="32"/>
            </padding>
            <Label fx:id="settingsErrorLabel" text="" styleClass="error-label" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            <Button fx:id="cancelButton" text="Cancel" onAction="#handleCancel" styleClass="btn-outlined-secondary"
                    prefWidth="100" prefHeight="40"/>
            <Button fx:id="saveButton" text="Save" onAction="#handleSave" styleClass="btn-primary"
                    prefWidth="100" prefHeight="40"/>
        </HBox>
    </bottom>

</BorderPane>
